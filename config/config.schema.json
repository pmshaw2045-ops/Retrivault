{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["rag", "llm", "embedding", "search", "paths"],
  "properties": {
    "rag": {
      "type": "object",
      "required": ["chunk_size", "chunk_overlap", "top_k", "similarity_threshold"],
      "properties": {
        "chunk_size": {
          "type": "integer", "minimum": 128, "maximum": 2048,
          "description": "分块大小（tokens），推荐 256/512/768/1024"
        },
        "chunk_overlap": {
          "type": "integer", "minimum": 0, "maximum": 512,
          "description": "相邻 chunk 之间重叠的 tokens 数"
        },
        "top_k": {
          "type": "integer", "minimum": 1, "maximum": 20,
          "description": "检索返回的最大结果数"
        },
        "similarity_threshold": {
          "type": "number", "minimum": 0.0, "maximum": 1.0,
          "description": "相似度阈值，低于此值的 chunk 被过滤"
        }
      }
    },
    "llm": {
      "type": "object",
      "required": ["model", "temperature", "max_tokens"],
      "properties": {
        "model": {
          "type": "string", "minLength": 1,
          "description": "模型标识符，如 deepseek-v4-pro、gpt-4o、qwen2.5:7b"
        },
        "temperature": {
          "type": "number", "minimum": 0.0, "maximum": 2.0,
          "description": "生成温度，越低越确定"
        },
        "max_tokens": {
          "type": "integer", "minimum": 256, "maximum": 16384,
          "description": "回答最大 token 数"
        }
      }
    },
    "embedding": {
      "type": "object",
      "required": ["model", "batch_size", "device"],
      "properties": {
        "model": {
          "type": "string", "minLength": 1,
          "description": "sentence-transformers 模型名，如 BAAI/bge-m3"
        },
        "batch_size": {
          "type": "integer", "minimum": 1, "maximum": 128,
          "description": "批量 Embedding 大小"
        },
        "device": {
          "type": "string", "enum": ["cpu", "cuda", "mps"],
          "description": "计算设备"
        }
      }
    },
    "search": {
      "type": "object",
      "required": ["mode", "rerank_enabled"],
      "properties": {
        "mode": {
          "type": "string", "enum": ["vector", "hybrid"],
          "description": "搜索模式"
        },
        "rerank_enabled": {
          "type": "boolean",
          "description": "是否启用重排（Phase 2）"
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["lancedb_dir", "sqlite_db"],
      "properties": {
        "lancedb_dir": {
          "type": "string", "minLength": 1,
          "description": "LanceDB 向量数据库目录"
        },
        "sqlite_db": {
          "type": "string", "minLength": 1,
          "description": "SQLite 状态数据库文件路径"
        }
      }
    }
  }
}
