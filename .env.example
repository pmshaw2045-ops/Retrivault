# ─────────────────────────────────────────────────
# Retrivault — 环境配置模板
# 复制此文件为 .env 后编辑：
#   cp .env.example .env
# ─────────────────────────────────────────────────

# 以下给出了三种典型配置方案：

# ── 方案 A：DeepSeek（推荐，2 个 API Key） ─────
# LLM + 改写用 DeepSeek，Embedding 用硅基流动 BGE-M3
# LLM_API_KEY=sk-deepseek...
# EMBEDDING_API_KEY=sk-siliconflow...

# ── 方案 B：OpenAI（换 LLM，其余不变） ─────────
# LLM_API_KEY=sk-openai...
# LLM_PROVIDER=openai
# EMBEDDING_API_KEY=sk-siliconflow...

# ── 方案 C：全离线（零费用，需下载模型） ──────
# 使用本地 Ollama + 本地 BGE-M3，无需任何 API Key
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=local
# 同时取消注释 requirements.txt 中的 torch / transformers

# ─────────────────────────────────────────────────
# 以下是各变量的详细说明
# ─────────────────────────────────────────────────

# Obsidian vault 路径（你的笔记目录）
# 不配则使用 docs/samples/ 中的示例文档
OBSIDIAN_VAULT_PATH=~/your-vault-path

# LLM API Key（DeepSeek / OpenAI）
# 仅在使用远程 LLM 时需要（方案 A/B）
LLM_API_KEY=

# LLM Provider（deepseek | openai | ollama）
LLM_PROVIDER=deepseek

# Embedding Provider（api | local）
# api = 远程 API（默认，需 EMBEDDING_API_KEY）
# local = 本地 BGE-M3（零费用，需下载 2.2GB 模型）
EMBEDDING_PROVIDER=api

# Embedding API Key
# 仅在使用 API Embedding 时需要（方案 A/B，默认）
# 硅基流动 BGE-M3（默认，需注册：https://cloud.siliconflow.cn）
EMBEDDING_API_KEY=

# Rerank API Key（与 Embedding 同一服务时可不填）
# RERANK_API_KEY=