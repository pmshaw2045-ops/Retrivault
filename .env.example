# ─────────────────────────────────────────────────
# Retrivault — 环境配置模板
# 复制此文件为 .env 后编辑：
#   cp .env.example .env
# ─────────────────────────────────────────────────

# ── 必填 ──────────────────────────────────────

# LLM API Key（DeepSeek / OpenAI / 任意兼容 API）
# 用于 LLM 生成 + Query 改写
LLM_API_KEY=sk-your-key-here

# Obsidian vault 路径（你的笔记目录）
# 不配则使用 docs/samples/ 中的示例文档
OBSIDIAN_VAULT_PATH=~/your-vault-path

# ── 建议填写 ─────────────────────────────────

# Embedding API Key（硅基流动 / OpenAI / 等）
# 默认使用硅基流动 + BGE-M3，需要在此填入 Key
# 注册：https://cloud.siliconflow.cn
EMBEDDING_API_KEY=sk-your-siliconflow-key

# Rerank API Key（若与 Embedding 同一服务，可留空复用）
# RERANK_API_KEY=

# ── 可选 ──────────────────────────────────────

# LLM Provider（deepseek | openai | ollama）
LLM_PROVIDER=deepseek

# Embedding 服务地址（默认硅基流动）
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# 使用本地 Embedding 时改为 local，无需 API Key
# 需先取消注释 requirements.txt 中的 sentence-transformers / torch / transformers
# EMBEDDING_PROVIDER=local

# 配置 profile 套餐（default / siliconflow / ollama-offline）
# 不设则用 default；详情查看 profiles/ 目录
# PROFILE=default
